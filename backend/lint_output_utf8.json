news.service.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Work\\web_pofolio\\backend\\src\\modules\\news\\rss.service.ts","messages":[{"ruleId":"@typescript-eslint/no-unsafe-assignment","severity":2,"message":"Unsafe assignment of an `any` value.","line":34,"column":11,"nodeType":"VariableDeclarator","messageId":"anyAssignment","endLine":34,"endColumn":56},{"ruleId":"@typescript-eslint/no-unsafe-member-access","severity":2,"message":"Unsafe member access ['media:content'] on an `any` value.","line":34,"column":40,"nodeType":"Literal","messageId":"unsafeMemberExpression","endLine":34,"endColumn":55},{"ruleId":"@typescript-eslint/no-unsafe-member-access","severity":2,"message":"Unsafe member access .$ on an `any` value.","line":41,"column":30,"nodeType":"Identifier","messageId":"unsafeMemberExpression","endLine":41,"endColumn":31},{"ruleId":"@typescript-eslint/no-unsafe-member-access","severity":2,"message":"Unsafe member access .$ on an `any` value.","line":42,"column":39,"nodeType":"Identifier","messageId":"unsafeMemberExpression","endLine":42,"endColumn":40}],"suppressedMessages":[],"errorCount":4,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { Injectable, Logger } from '@nestjs/common';\nimport RSSParser from 'rss-parser';\n\nexport interface NormalizedNews {\n  title: string;\n  description: string;\n  thumbnail: string;\n  url: string;\n  source: string;\n  publishedAt: Date;\n}\n\n@Injectable()\nexport class RssService {\n  private readonly logger = new Logger(RssService.name);\n  private parser: RSSParser = new RSSParser();\n\n  async fetchFeed(url: string, sourceName: string): Promise<NormalizedNews[]> {\n    try {\n      const feed = await this.parser.parseURL(url);\n      return feed.items.map((item) => this.normalize(item, sourceName));\n    } catch (error) {\n      this.logger.error(\n        `Failed to fetch RSS from ${sourceName}: ${url}`,\n        error,\n      );\n      return [];\n    }\n  }\n\n  private normalize(item: RSSParser.Item, source: string): NormalizedNews {\n    let thumbnail = '';\n\n    const mediaContent = (item as any)['media:content'];\n    if (item.enclosure?.url) {\n      thumbnail = item.enclosure.url;\n    } else if (item.content) {\n      // Regex to find first img src in content\n      const imgMatch = item.content.match(/<img[^>]+src=\"([^\">]+)\"/);\n      if (imgMatch) thumbnail = imgMatch[1];\n    } else if (mediaContent?.$?.url) {\n      thumbnail = String(mediaContent.$.url);\n    }\n\n    // Clean description: remove HTML tags\n    const description = (item.contentSnippet || item.content || '')\n      .replace(/<[^>]*>?/gm, '')\n      .substring(0, 250);\n\n    return {\n      title: item.title || 'No Title',\n      description,\n      thumbnail,\n      url: item.link || '',\n      source,\n      publishedAt: item.pubDate ? new Date(item.pubDate) : new Date(),\n    };\n  }\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Work\\web_pofolio\\backend\\src\\modules\\posts\\dto\\create-post.dto.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Work\\web_pofolio\\backend\\src\\modules\\posts\\dto\\update-post.dto.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Work\\web_pofolio\\backend\\src\\modules\\posts\\posts.controller.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Work\\web_pofolio\\backend\\src\\modules\\posts\\posts.module.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCoun